{
  "$schema": "https://json.schemastore.org/nest-cli.json",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "builder": "swc",
    "typeCheck": false,
    "plugins": ["@nestjs/swagger"]
  },
  "generateOptions": {
    "spec": false
  }
}