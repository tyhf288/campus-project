{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@campus/utils",
  "version": "1.0.0",
  "description": "Shared utility functions for the monorepo",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint:format": "prettier --write \"src/**/*.ts\" ",
    "lint:fix": "eslint src/**/*.ts --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@campus/types": "workspace:*",
    "@campus/eslint-config": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "vitest": "^4.1.10"
  }
}
