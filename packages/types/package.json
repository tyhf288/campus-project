{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@campus/types",
  "version": "1.0.0",
  "description": "Shared TypeScript types for the monorepo",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint:format": "prettier --write \"src/**/*.ts\" ",
    "lint:fix": "eslint src/**/*.ts --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@campus/eslint-config": "workspace:*"
  },
  "devDependencies": {
    "typescript": "~5.7.0",
    "tsup": "^8.5.1"
  }
}
