{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@campus/types",
  "version": "1.0.0",
  "description": "Shared TypeScript types for the monorepo",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint:format": "prettier --write \"src/**/*.ts\" ",
    "lint:fix": "eslint src/**/*.ts --fix",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@campus/eslint-config": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}